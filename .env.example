APP_NAME=event-intel-api
APP_ENV=development
DEBUG=true
PORT=8000
DATABASE_URL=sqlite:///./event_intel.db
DEFAULT_RADIUS_KM=10
CLUSTER_DISTANCE_KM=1.5
CLUSTER_TIME_WINDOW_HOURS=12
SOURCE_TIMEOUT_SECONDS=20
ENABLE_MOCK_ADAPTERS=true

# Auth — set a strong random string to enable API key enforcement.
# Requests must include header: X-API-Key: <value>
# Leave blank to disable in development.
API_KEY=

# CORS — comma-separated allowed origins. Use "*" to allow all (default).
# Set to your frontend domain in production: https://yourapp.com
CORS_ORIGINS_RAW=*

# Webhooks — comma-separated URLs to POST when an event confidence >= 0.75.
# Payload: {"event": "event.confirmed", "event_id": ..., "title": ..., ...}
# Leave blank to disable.
WEBHOOK_URLS=

# Embeddings — multilingual sentence embeddings for clustering.
# Model is downloaded on first use (~50MB). Set EMBEDDINGS_ENABLED=false to
# skip entirely and use Jaccard bag-of-words similarity instead.
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDINGS_ENABLED=true

# Source credentials
EVENTBRITE_PRIVATE_TOKEN=
LUMA_FEED_URLS=
TELEGRAM_FEED_URLS=
X_BEARER_TOKEN=
LINKEDIN_SOURCE_URLS=

# Scheduler: JSON array of ingest jobs.
# Each: {"source": "luma", "city": "Lagos", "query": "web3", "interval_minutes": 60}
SCHEDULER_SOURCES=
