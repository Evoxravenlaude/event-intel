{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {"builder": "DOCKERFILE"},
  "deploy": {
    "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}",
    "healthcheckPath": "/health",
    "restartPolicyType": "ON_FAILURE"
  },
  "services": {
    "api": {
      "startCommand": "uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000}"
    },
    "worker": {
      "startCommand": "python -m app.workers.run_once"
    },
    "scheduler": {
      "startCommand": "python -m app.workers.scheduler"
    },
    "backfill": {
      "startCommand": "python -m app.workers.backfill_embeddings",
      "notes": "Run once after enabling embeddings on an existing database"
    }
  }
}
